# Set seed for reproducibility
np.random.seed(42)

# 1. Generate the 'True Signal' (e.g., a slow, structural market trend)
days = np.arange(200)
true_signal = np.sin(days / 20) * 2 + (days / 50)

# 2. Generate the 'Market Noise' (High variance stochasticity)
market_noise = np.random.normal(loc=0, scale=1.5, size=200)

# 3. Combine to create the 'Observable Market Price'
observable_price = true_signal + market_noise

# Plotting the challenge outlined in Section 1.1
plt.figure(figsize=(10, 5))
plt.plot(days, observable_price, label='Observable Market Data (Signal + Noise)', color='lightgray')
plt.plot(days, true_signal, label='Hidden Structural Signal', color='blue', linewidth=2)
plt.xlabel('Time (Days)')
plt.ylabel('Asset Price')
plt.legend()
plt.grid(True, alpha=0.3)
plt.show()
